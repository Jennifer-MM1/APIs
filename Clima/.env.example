# API Key de OpenWeatherMap (https://openweathermap.org/api)
OPENWEATHER_API_KEY=tu_api_key_aqui

# Tiempo de vida del cache en segundos (default: 600 = 10 minutos)
CACHE_TTL_SECONDS=600

# Idioma de las descripciones del clima (default: es)
DEFAULT_LANG=es

# Unidades de medida: metric (°C), imperial (°F), standard (°K)
DEFAULT_UNITS=metric
