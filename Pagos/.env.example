# ============================================================
#  API de Pagos — Variables de Entorno
# ============================================================

# --- Base de datos ---
# Para desarrollo local (SQLite, no necesita nada extra):
DATABASE_URL=sqlite:///pagos.db
# Para Turso en producción (necesita pip install sqlalchemy-libsql):
# DATABASE_URL=sqlite+libsql://tu-base-de-datos-tu-usuario.turso.io?secure=true
# TURSO_AUTH_TOKEN=tu-token-aqui

# --- JWT (debe coincidir con tu API de Autenticación) ---
SECRET_KEY=tu-clave-secreta-compartida
ALGORITHM=HS256

# --- Moneda por defecto ---
DEFAULT_CURRENCY=MXN

# --- Stripe (opcional) ---
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# --- PayPal (opcional) ---
# PAYPAL_CLIENT_ID=tu-client-id
# PAYPAL_CLIENT_SECRET=tu-client-secret
# PAYPAL_MODE=sandbox

# --- MercadoPago (opcional) ---
# MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxx
